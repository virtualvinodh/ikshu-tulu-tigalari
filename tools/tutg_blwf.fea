        sub conjoiner-tutg va_uMatra-tutg by va_uMatra-tutg.below.auto;
        sub conjoiner-tutg va_uuMatra-tutg by va_uuMatra-tutg.below.auto;
        sub conjoiner-tutg va_va-tutg by va_va-tutg.below.auto;
        sub conjoiner-tutg va_ya-tutg by va_ya-tutg.below.auto;
        sub conjoiner-tutg ya_lVocalicMatra-tutg by ya_lVocalicMatra-tutg.below.auto;
        sub conjoiner-tutg ya_va-tutg by ya_va-tutg.below.auto;
        sub conjoiner-tutg ya_ya-tutg by ya_ya-tutg.below.auto;
    } TutgBlwf;
} blwf;

