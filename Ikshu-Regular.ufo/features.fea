        sub ddha-tutg vs1-tutg by ddha-tutg.alt1;
        sub ee-tutg vs1-tutg by ee-tutg.alt1;
        sub gha-tutg vs1-tutg by gha-tutg.alt1;
        sub gha-tutg vs2-tutg by gha-tutg.alt2;
        sub ii-tutg vs1-tutg by ii-tutg.alt1;
        sub ii-tutg vs2-tutg by ii-tutg.alt2;
        sub iiMatra-tutg vs1-tutg by iiMatra-tutg.alt1;
        sub jha-tutg vs1-tutg by jha-tutg.alt1;
        sub jha-tutg vs2-tutg by jha-tutg.alt2;
        sub jha-tutg vs3-tutg by jha-tutg.alt3;
        sub kha-tutg vs1-tutg by kha-tutg.alt1;
        sub kha-tutg vs2-tutg by kha-tutg.alt2;
        sub lVocalicMatra-tutg vs1-tutg by lVocalicMatra-tutg.alt;
        sub llVocalic-tutg vs1-tutg by llVocalic-tutg.alt1;
        sub lla-tutg vs1-tutg by lla-tutg.alt1;
        sub llla-tutg vs1-tutg by llla-tutg.alt1;
        sub ma-tutg vs1-tutg by ma-tutg.alt1;
        sub ma-tutg vs2-tutg by ma-tutg.alt2;
        sub nga-tutg vs1-tutg by nga-tutg.alt1;
        sub nya-tutg vs1-tutg by nya-tutg.alt1;
        sub nya-tutg vs2-tutg by nya-tutg.alt2;
        sub oo-tutg vs1-tutg by oo-tutg.alt1;
        sub oo-tutg vs2-tutg by oo-tutg.alt2;
        sub rVocalicMatra-tutg vs1-tutg by rVocalicMatra-tutg-alt1;
        sub ra-tutg vs1-tutg by ra-tutg.alt1;
        sub repha-tutg vs1-tutg by repha-tutg.alt1;
        sub rrVocalic-tutg vs1-tutg by rrVocalic-tutg.alt1;
        sub rrVocalic-tutg vs2-tutg by rrVocalic-tutg.alt2;
        sub rra-tutg vs1-tutg by rra-tutg.alt1;
        sub uMatra-tutg vs1-tutg by uMatra-tutg.alt1;
        sub uMatra-tutg vs2-tutg by uMatra-tutg.alt2;
        sub uMatra-tutg vs3-tutg by uMatra-tutg.alt3;
        sub uMatra-tutg vs4-tutg by uMatra-tutg.alt4;
        sub uMatra-tutg vs5-tutg by uMatra-tutg.alt5;
        sub uMatra-tutg vs6-tutg by uMatra-tutg.alt6;
        sub uu-tutg vs1-tutg by uu-tutg.alt1;
        sub uu-tutg vs2-tutg by uu-tutg.alt2;
        sub uuMatra-tutg vs1-tutg by uuMatra-tutg.alt1;
        sub uuMatra-tutg vs2-tutg by uuMatra-tutg.alt2;
        sub uuMatra-tutg vs3-tutg by uuMatra-tutg.alt3;
        sub uuMatra-tutg vs4-tutg by uuMatra-tutg.alt4;
        sub va-tutg vs1-tutg by va-tutg.alt1;
    } TutgVariantSelect;
    lookup TutgSubjoinerForm {
        # Conjoiner + VS1 -> subjoiner-tutg (forces below-base stacking - see blwf's TutgBlwfSubjoiner).
        sub conjoiner-tutg vs1-tutg by subjoiner-tutg;
    } TutgSubjoinerForm;
    lookup TutgRephaUpgrade {
        # Typed Repha (repha-tutg) -> ligating variant (repha-tutg.alt1).
        sub repha-tutg by repha-tutg.alt1;
    } TutgRephaUpgrade;
    lookup TutgAkhand {
